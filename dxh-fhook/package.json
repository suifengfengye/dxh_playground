{
  "name": "dxh-fhook",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "lint": "eslint \"{packages,apps}/**/*\"",
    "spellcheck": "cspell lint --dot --gitignore --color --cache --show-suggestions \"(packages|apps)/**/*.@(html|js|cjs|mjs|ts|tsx|css|scss|md)\"",
    "commit": "git-cz",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3",
  "config": {
    "commitizen": {
      "path": "cz-git"
    }
  },
  "lint-staged": {
    "**/*.{js,jsx}": [
      "eslint --fix",
      "prettier --cache --write"
    ],
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --cache --write --parser=typescript"
    ]
  },
  "devDependencies": {
    "eslint": "10.3.0",
    "@eslint/js": "10.0.1",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "typescript": "6.0.3",
    "path-browserify": "1.0.1",
    "typescript-eslint": "8.59.2",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "eslint-plugin-prettier": "5.5.5",
    "lint-staged": "17.0.2",
    "cspell": "9.2.2",
    "commitlint": "20.5.3",
    "commitizen": "4.3.1",
    "cz-git": "1.13.0",
    "husky": "9.1.7"
  }
}
